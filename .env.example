# ============================================================
# SUPABASE - DATABASE & AUTHENTICATION
# ============================================================
# Public keys (safe in frontend)

# आपका Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous (Anon) Key - Frontend से access के लिए
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Publishable Key (optional)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Server-only keys (backend only - NEVER expose in frontend)

# अपना Supabase Project URL again (server-side)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (server-side)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# EMAIL - GMAIL SMTP (PRIMARY)
# ============================================================
# Gmail के SMTP server से भेजने के लिए

# Gmail SMTP host
EMAIL_HOST=smtp.gmail.com

# Gmail SMTP port
EMAIL_PORT=587

# Secure connection (TLS)
EMAIL_SECURE=false

# आपका Gmail address
EMAIL_USER=your-email@gmail.com

# Gmail App Password (16 characters)
# नोट: Regular password काम नहीं करेगा, App Password चाहिए
# https://myaccount.google.com/apppasswords से generate करें
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ============================================================
# EMAIL - RESEND (FALLBACK/OPTIONAL)
# ============================================================
# अगर Gmail काम न करे तो Resend से email भेजेगा
# https://resend.com से API key लें

# Resend API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Resend से email भेजने वाली email address
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# NEXT.JS / VERCEL
# ============================================================

# Development/Production mode
NODE_ENV=development

# ============================================================
# ANALYTICS (OPTIONAL)
# ============================================================

# आपकी analytics service की ID (अगर use करते हो)
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
# 1. .env.example को .env.local से rename करें
# 2. अपनी actual values डालें
# 3. .env.local को .gitignore में रखें (sensitive data के लिए)
# 4. Vercel deploy करते समय Vercel UI में values add करें
